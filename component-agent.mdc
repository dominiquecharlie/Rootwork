## Required Component Patterns

### Draft Label (Required on All Claude Output)
```jsx
// Use this component everywhere Claude output is displayed
export function DraftLabel({ context = "AI draft — review and edit before use" }) {
  return (
    <div className="flex items-center gap-2 px-3 py-1.5 bg-amber-50 border border-amber-200 rounded text-sm text-amber-800 font-medium mb-3">
      <span>⚠</span>
      <span>{context}</span>
    </div>
  );
}

// Usage
<DraftLabel />
<DraftLabel context="AI-extracted — confirm against original document" />
<DraftLabel context="AI-surfaced — verify before acting" />
```

### Stage Gate Locked State
```jsx
// Show this when a stage is locked — never just hide content
export function StageLocked({ reason, requiredAction }) {
  return (
    <div className="border-2 border-rw-green-light rounded-lg p-8 text-center bg-rw-warm-white">
      <div className="text-rw-green font-georgia text-xl font-bold mb-3">
        This stage is not yet available
      </div>
      <p className="text-rw-charcoal mb-4">{reason}</p>
      {requiredAction && (
        <p className="text-sm text-rw-charcoal/70">
          Required: {requiredAction}
        </p>
      )}
    </div>
  );
}
```

### Community Voice Display (Verbatim Only)
```jsx
// Community voice is always displayed verbatim — never summarized
// This component enforces that visually
export function CommunityVoiceRecord({ record }) {
  return (
    <blockquote className="border-l-4 border-rw-green pl-4 py-2 my-3 bg-rw-warm-white rounded-r">
      <p className="text-rw-charcoal italic">"{record.voice_content}"</p>
      <footer className="text-sm text-rw-charcoal/60 mt-1">
        {record.speaker_role} · {record.engagement_context}
      </footer>
    </blockquote>
  );
}
// ❌ Never pass community voice through a summarizer before display
// ❌ Never display "Key themes from community input: ..."
```

### Form Field with Equity Prompt
```jsx
// Guided prompts in Stage 01 follow this pattern
export function EquityPromptField({ label, prompt, hint, value, onChange, name }) {
  return (
    <div className="mb-6">
      <label className="block font-georgia font-bold text-rw-green text-lg mb-1">
        {label}
      </label>
      {prompt && (
        <p className="text-rw-charcoal/80 text-sm mb-3 leading-relaxed">{prompt}</p>
      )}
      <textarea
        name={name}
        value={value}
        onChange={onChange}
        className="w-full border border-rw-green-light rounded p-3 text-rw-charcoal bg-white focus:outline-none focus:ring-2 focus:ring-rw-green min-h-[120px]"
      />
      {hint && (
        <p className="text-xs text-rw-charcoal/50 mt-1">{hint}</p>
      )}
    </div>
  );
}
```

