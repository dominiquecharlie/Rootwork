## Claude API Call Pattern (Server-Side)

All Claude calls follow this pattern. Never deviate from it.

```js
import Anthropic from '@anthropic-ai/sdk';
import { logClaudeInteraction } from '../utils/claudeLogger.js';

const anthropic = new Anthropic({ apiKey: process.env.ANTHROPIC_API_KEY });

export async function callClaude({ orgId, userId, stage, interactionType, systemPrompt, userPrompt }) {
  const response = await anthropic.messages.create({
    model: 'claude-sonnet-4-6',
    max_tokens: 2000,
    system: systemPrompt,
    messages: [{ role: 'user', content: userPrompt }]
  });

  const output = response.content[0].text;

  // Log every interaction — required
  await logClaudeInteraction({
    orgId,
    userId,
    stage,
    interactionType,
    outputSummary: output.slice(0, 300), // Non-sensitive summary only
    tokensUsed: response.usage.input_tokens + response.usage.output_tokens
  });

  return output;
}
```

