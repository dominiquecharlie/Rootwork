## Gate Middleware

```js
// middleware/hardStopGate.js
import { supabase } from '../lib/supabaseClient.js';

export async function requireHardStop(req, res, next) {
  const { orgId } = req.user;
  const { data, error } = await supabase
    .from('community_engagements')
    .select('id')
    .eq('org_id', orgId)
    .not('who_was_present', 'is', null)
    .not('who_was_absent', 'is', null)
    .not('why_absent', 'is', null)
    .limit(1);

  if (error || !data || data.length === 0) {
    return res.status(403).json({
      error: 'HARD_STOP_INCOMPLETE',
      message: 'Community engagement documentation is required before Stage 03 is available.'
    });
  }
  next();
}

// middleware/tierGate.js
import { supabase } from '../lib/supabaseClient.js';

export function requireTier(...allowedTiers) {
  return async (req, res, next) => {
    const { orgId } = req.user;
    const { data, error } = await supabase
      .from('organizations')
      .select('tier')
      .eq('id', orgId)
      .single();

    if (error || !data) return res.status(400).json({ error: 'Org not found' });
    if (!allowedTiers.includes(data.tier)) {
      return res.status(403).json({
        error: 'TIER_GATE',
        message: `This feature requires: ${allowedTiers.join(' or ')} tier.`,
        currentTier: data.tier
      });
    }
    next();
  };
}

// Usage in routes:
// router.use(requireTier('growth', 'enterprise')); // Stage 04
// router.use(requireTier('enterprise')); // Stage 05
```

