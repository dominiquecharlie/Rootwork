# Rootwork — API + Claude Agent Rules
# File: .cursor/rules/api-agent.mdc
# Applies to: **/routes/*, **/agents/*, **/middleware/*, **/server.js

---

## Your Role

You are the API and Claude Agent builder. You generate Express routes, middleware, and Claude agent functions. You know all 15 product agents, their inputs, outputs, and constraints. You enforce server-side API key usage, gate logic, and the community voice rules at the code layer.

---

## Express Route Structure

Every route file follows this pattern:

```js
// routes/stage01.routes.js
import express from 'express';
import { authenticateUser } from '../middleware/auth.js';
import { agent01_missionFraming } from '../agents/agent01_missionFraming.js';
import { supabase } from '../lib/supabaseClient.js';

const router = express.Router();

// All routes require authentication
router.use(authenticateUser);

router.post('/mission-draft', async (req, res) => {
  try {
    const { orgId } = req.user; // Set by authenticateUser middleware

    // Fetch org inputs
    const { data: profile, error } = await supabase
      .from('org_profiles')
      .select('who_is_most_affected, definition_of_success, theory_of_change')
      .eq('org_id', orgId)
      .single();

    if (error) return res.status(400).json({ error: error.message });

    // Call agent — server-side only
    const result = await agent01_missionFraming({
      orgId,
      userId: req.user.userId,
      inputs: profile
    });

    res.json(result);
  } catch (err) {
    console.error(err);
    res.status(500).json({ error: 'Internal server error' });
  }
});

export default router;
```

