## Claude Interaction Logger

```js
// utils/claudeLogger.js
import { supabase } from '../lib/supabaseClient.js';

export async function logClaudeInteraction({
  orgId, userId, stage, interactionType,
  promptSummary, outputSummary, tokensUsed
}) {
  const { error } = await supabase.from('claude_interactions').insert({
    org_id: orgId,
    user_id: userId,
    stage,
    interaction_type: interactionType,
    prompt_summary: promptSummary,
    output_summary: outputSummary,
    model: 'claude-sonnet-4-6',
    tokens_used: tokensUsed
  });

  if (error) {
    // Log to console but don't throw — interaction logging should never crash the response
    console.error('Claude interaction log failed:', error.message);
  }
}
```

